# ============================================
# CLap - Environment Variables
# Copy file này thành .env rồi điền giá trị
# ============================================

# --- Flask ---
SECRET_KEY=change-me-in-production
FLASK_DEBUG=True

# --- MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=laptop_shop
DB_PASSWORD=shop123
DB_NAME=laptop_pricing

# --- OpenAI (cho CrewAI multi-agent, tuỳ chọn) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Scraping ---
SCRAPE_INTERVAL_MINUTES=60
HEADLESS_BROWSER=True

# --- Business Rules ---
INVENTORY_THRESHOLD=100
OVERSTOCK_DISCOUNT_PERCENT=5.0
COMPETITOR_OUT_MARKUP_PERCENT=10.0
HIGH_DEMAND_MARKUP_PERCENT=8.0
